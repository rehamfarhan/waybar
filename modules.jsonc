{
    "hyprland/window": {
        "format": "{title}",
        "max-length": 25,
        "on-click": "hyprctl dispatch workspace empty && omarchy-launch-walker",
        "on-click-right": "hyprctl dispatch killactive",
        "on-click-middle": "hyprctl dispatch togglespecialworkspace",
        "rewrite": {
            "": "Omarchy",
            "(.*) έΑΦ Mozilla Firefox": "ΎΚσ $1",
            "(.*) - Visual Studio Code": "≤░ρη $1",
            "(.*) - Thunar": "ΎΒ╝ $1",
            "(.*) - Discord": "ΎΟΤ $1",
            "(.*) - Spotify": "ΎΗ╝ $1",
            "(.*) - Kitty": "ΌηΧ $1",
            "(.*) - Ghostty": "ΌηΧ $1"
        },
        "icon": false,
        "separate-output": true
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{name}",
        "format-icons": {
            "active": " ",
            "default": " ",
            "empty": ""
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "window-rewrite": {
            "title<.*youtube.*>": "ΎΖς ", 
            "(.*) - Chromium": "ΎΚρ ",
            "(.*) - Firefox": "ΎΚσ ",
            "(.*) - Brave": "ΎΚρ ",
            "(.*) - Google": "ΎΗι ",
            "(.*)VSCodium": "≤░ρη ",
            "class<Codium>": "≤░ρη ",
            "(.*) - Thunar": "ΎΒ╝ ",
            "class<discord>": "ΎΟΤ ",
            "class<WhatsApp>": "ΎΙ▓ ",
            "class<org.telegram.desktop>": "ΎΜΗ ",
            "class<slack>": "ΎΗΩ ",
            "class<zoom>": "≤░αΦ ",
            "class<signal>": "≤░ΙΟ ",
            "class<obsidian>": "≤▒Υπ ",
            "WhatsApp": "ΎΙ▓ ",
            "Ghostty": "ΌηΧ ",
            "class<com.mitchellh.ghostty>": "ΌηΧ ",
            "class<spotify>": "ΎΗ╝ ",
            "class<notion>": "ΎΚΚ ",
            "title<.*Gemini.*>": "≤░φ╣ ",
            "title<.*Grok.*>": "≤▒γμ ",
            "title<.*ChatGPT.*>": "≤░φ╣ ",
            "title<.*Claude.*>": "≤░φ╣ "
	},
        "persistent-workspaces": {
            // Keep empty to only show active/occupied workspaces
        }
    },

    "cpu": {
        "interval": 2,
        "format": "ΎΤ╝ {usage}%",
        "on-click": "ghostty -e btop",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },

    "memory": {
        "interval": 2,
        "format": "ΌΚο {percentage}%",
        "format-alt": "ΌΚο {used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "ghostty -e btop",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-"
    },


    "clock": {
        "interval": 1,
        "format": "≤░ξΦ {:%I:%M %p}", // Includes seconds and a clock icon
        "format-alt": "≤░Δφ {:%A, %B %d, %Y (%R)}", // Detailed date view
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
           "mode": "month",
           "mode-mon-col": 3,
           "weeks-pos": "right",
           "on-scroll": 1,
             "format": {
             "months":   "<span color='#ffead3'><b>{}</b></span>",
             "days":     "<span color='#ecc6d9'><b>{}</b></span>",
             "weeks":    "<span color='#99ffdd'><b>W{}</b></span>",
             "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
             "today":    "<span color='#ff6699'><b><u>{}</u></b></span>"
        }
    },

    "actions": {
        "on-click-right": "mode",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
    }
},

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "tooltip": true,
        "format-muted": "Ύγσ",
        "on-click": "pamixer -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        }
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ ",
        "on-click": "pamixer --default-source -t",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },

    "network": {
        "format-wifi": "{essid} ΎΘτ ",
        "format-ethernet": "≤░ΙΑ",
        "tooltip-format": "IP: {ipaddr}/{cidr}\nGateway: {gwaddr}\nDown: ΎΕ║ {bandwidthDownBytes}\nUp: ΎΕ╣ {bandwidthUpBytes}",
        "format-disconnected": "≤░Νβ",
        "on-click-right": "ghostty -e nmtui",
        "interval": 1
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "custom/exams": {
        "exec": "python3 ~/.config/waybar/scripts/exams.py",
        "return-type": "json",
        "interval": 3600,
        "tooltip": true
    },

    "custom/ramadan": {
        "exec": "python3 ~/.config/waybar/scripts/ramadan.py",
        "return-type": "json",
        "interval": 60,
        "tooltip": true,
        "format": "{}", 
        "on-click": "notify-send 'Ramadan Schedule' '$(python3 ~/.config/waybar/scripts/ramadan.py | jq -r .tooltip)'"
    },

    "custom/sleep": {
        "exec": "python3 ~/.config/waybar/scripts/sleep_warning.py",
        "return-type": "json",
        "interval": 60,
        "tooltip": true
    },

    "custom/gamemode": {
        "format": "≤░ΥΥ ",
        "on-click": "sh ~/.config/waybar/scripts/gamemode.sh",
        "tooltip": true,
        "tooltip-format": "Toggle Gamemode (Performance)"
    },

    "custom/user": {
        "exec": "sh ~/.config/waybar/scripts/user.sh",
        "return-type": "json",
        "interval": 1800,
        "tooltip": true
    },

    "custom/media": {
        "format": "{}",
        "return-type": "json",
        "max-length": 60,
        "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip": true
    }
}
